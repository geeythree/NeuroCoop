# Filecoin network — Protocol Labs native chain (FVM is EVM-compatible)
# calibration = testnet (default) | mainnet = production
FILECOIN_NETWORK=calibration

# Calibration testnet RPC (default — no change needed for testnet)
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# Mainnet RPC (uncomment if FILECOIN_NETWORK=mainnet)
# FILECOIN_RPC_URL=https://api.node.glif.io/rpc/v1

# NeuroCoop contract address (deploy NeuroCoop.sol to Filecoin Calibration first)
# Faucet: https://faucet.calibnet.chainsafe-fil.io/
# Deploy via Remix: https://remix.ethereum.org (add Filecoin Calibration network)
COOP_ADDRESS=

# Deployer/first member wallet
OWNER_PRIVATE_KEY=

# Storacha (decentralized storage on IPFS/Filecoin — Protocol Labs)
# Create space at https://console.storacha.network/
STORACHA_EMAIL=

# Venice AI (Cognition module — ethics analysis, neural insights, governance health)
# Private inference, zero data retention: https://venice.ai
VENICE_API_KEY=

# Server
PORT=3000
